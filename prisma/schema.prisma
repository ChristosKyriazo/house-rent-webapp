generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  key             String    @unique @default(cuid())
  email           String    @unique
  name            String?
  dateOfBirth     DateTime?
  clerkUserId     String?   @unique
  title           String?
  occupation      String?
  role            String    @default("user") // "owner", "user", or "both"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  homes           Home[]
  ratingsReceived Rating[]       @relation("RatedUser")
  ratingsGiven    Rating[]       @relation("Rater")
  inquiries       Inquiry[]
  notifications   Notification[] @relation

  @@map("users")
}

model Home {
  id                Int      @id @default(autoincrement())
  key               String   @unique @default(cuid())
  title             String
  description       String?
  street            String?
  city              String
  country           String
  area              String?  // City area (e.g., "Nea Smirni")
  listingType       String   @default("rent")
  pricePerMonth     Int
  bedrooms          Int
  bathrooms         Int
  floor             Int?
  heatingCategory   String?  // "central" or "autonomous"
  heatingAgent      String?  // "oil", "natural gas", "electricity", "other"
  sizeSqMeters      Int?
  yearBuilt         Int?
  yearRenovated     Int?
  availableFrom     DateTime
  photos            String?  // JSON array of photo file paths/URLs
  finalized         Boolean  @default(false) // Whether any inquiry for this home has been finalized
  closestMetro      Float?   // Distance to closest metro (in km or minutes)
  closestBus        Float?   // Distance to closest bus stop (in km or minutes)
  closestSchool     Float?   // Distance to closest school (in km or minutes)
  closestKindergarten Float? // Distance to closest kindergarten (in km or minutes)
  closestHospital   Float?  // Distance to closest hospital (in km or minutes)
  closestPark       Float?   // Distance to closest park (in km or minutes)
  parking           Boolean? // Whether parking is available (yes/no)
  ownerId           Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  inquiries         Inquiry[]

  @@index([finalized])

  @@index([city])
  @@index([ownerId])
  @@index([listingType])
  @@index([area])
  @@map("homes")
}

model Rating {
  id          Int      @id @default(autoincrement())
  key         String   @unique @default(cuid())
  raterId     Int
  ratedUserId Int
  type        String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ratedUser   User     @relation("RatedUser", fields: [ratedUserId], references: [id], onDelete: Cascade)
  rater       User     @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)

  // Removed unique constraint to allow multiple ratings between same users over time
  @@index([ratedUserId])
  @@index([type])
  @@index([raterId, ratedUserId, type]) // Index for efficient queries
  @@map("ratings")
}

model Inquiry {
  id          Int      @id @default(autoincrement())
  key         String   @unique @default(cuid())
  userId      Int
  homeId      Int
  approved    Boolean  @default(false)
  dismissed   Boolean  @default(false)
  finalized   Boolean  @default(false) // Whether the deal has been finalized
  finalizedBy Int?     // User ID who initiated finalization (null if not finalized)
  contactInfo String?  // JSON string with contact information (name, email, phone, timeSchedule, useContactPerson)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  home        Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([userId, homeId])
  @@index([userId])
  @@index([homeId])
  @@index([approved])
  @@index([dismissed])
  @@index([finalized])
  @@map("inquiries")
}

model Notification {
  id          Int       @id @default(autoincrement())
  key         String    @unique @default(cuid())
  recipientId Int       // User who receives the notification
  role        String    // "owner" or "user" - the role of the recipient
  type        String    // "inquiry", "approved", "dismissed", or "finalize"
  homeKey     String?   // Home key (for users, this is the owner's home)
  userId      Int?      // User ID (for owners, this is the user who inquired)
  ownerKey    String?   // Owner key (for users, this is the owner's key)
  inquiryId   Int?      // Inquiry ID (for finalize notifications)
  deleted     Boolean   @default(false) // Whether the notification has been deleted
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  recipient   User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([deleted])
  @@index([type])
  @@map("notifications")
}

model Area {
  id          Int      @id @default(autoincrement())
  key         String   @unique @default(cuid())
  name        String   // Area name (e.g., "Nea Smirni")
  nameGreek   String?  // Area name in Greek
  city        String?  // Optional city filter
  cityGreek   String?  // City name in Greek
  country     String?  // Optional country filter
  countryGreek String? // Country name in Greek
  safety      Float?   // Safety rating (0-10 or similar scale)
  vibe        String?  // Vibe description (e.g., "family-friendly", "vibrant", "quiet")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([city])
  @@index([country])
  @@map("areas")
}
