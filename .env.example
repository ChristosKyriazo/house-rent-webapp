# Copy to .env and adjust. Never commit .env.

# Resolved relative to prisma/schema.prisma — use ./dev.db for prisma/dev.db (not ./prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Clerk — required for auth (https://dashboard.clerk.com)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Optional — AI / maps features
# OPENAI_API_KEY=
# GOOGLE_MAPS_API_KEY=
