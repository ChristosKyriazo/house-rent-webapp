{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed:universities": "npx --yes tsx@4.19.2 scripts/seeds/seed-universities.ts",
    "db:seed:nea-smirni": "npx --yes tsx@4.19.2 scripts/seeds/seed-nea-smirni.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.5",
    "@prisma/client": "^5.18.0",
    "next": "16.0.10",
    "openai": "^6.15.0",
    "prisma": "^5.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.18",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
